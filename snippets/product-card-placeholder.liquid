{%- liquid
  assign placeholder_names = 'Gradient Graphic T-Shirt,Polo with Tipping Details,Black Striped T-Shirt,Skinny Fit Jeans' | split: ','
  assign placeholder_prices = '$145,  $212, $180, $240' | split: ','
  assign placeholder_name = placeholder_names[index | minus: 1]
  assign placeholder_price = placeholder_prices[index | minus: 1]
-%}

<article class="product-card">
  <div class="product-card__image-wrap" style="cursor:default;">
    {{ 'product-' | append: index | placeholder_svg_tag: 'product-card__image' }}
  </div>
  <div class="product-card__info">
    <h3 class="product-card__name">{{ placeholder_name }}</h3>
    <div class="product-card__rating">
      <div class="stars" aria-hidden="true">★★★★★</div>
      <span class="rating-count">4.5/5</span>
    </div>
    <div class="product-card__price">
      <span class="price">{{ placeholder_price }}</span>
    </div>
  </div>
</article>
