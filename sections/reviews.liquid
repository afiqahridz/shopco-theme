<section class="reviews-section section" aria-label="Customer testimonials">
  <div class="container">
    <div class="flex-between" style="margin-bottom:40px;" data-animate>
      <h2 class="section-title" style="margin-bottom:0;text-align:left;">Our Happy Customers</h2>
      <div class="reviews-controls">
        <button class="review-btn" id="reviews-prev" aria-label="Previous reviews">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="review-btn" id="reviews-next" aria-label="Next reviews">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="reviews-track-wrap">
      <div class="reviews-track" id="reviews-track">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <article class="review-card" {{ block.shopify_attributes }}>
              <div class="review-card__stars stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                {%- assign rating = block.settings.rating | times: 1 -%}
                {%- for i in (1..5) -%}
                  <span class="star" aria-hidden="true">{%- if i <= rating -%}★{%- else -%}☆{%- endif -%}</span>
                {%- endfor -%}
              </div>
              <div class="review-card__name">
                {{ block.settings.author }}
                <svg class="verified-icon" width="16" height="16" viewBox="0 0 24 24" fill="#4CAF50" aria-label="Verified purchase">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01" fill="none" stroke="#fff" stroke-width="2"/>
                </svg>
              </div>
              <p class="review-card__text">"{{ block.settings.text }}"</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Reviews",
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "author", "label": "Customer name", "default": "Sarah M." },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "I'm blown away by the quality and style of the clothes I received from Shop.co. Every piece I've bought has exceeded my expectations." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        { "type": "review", "settings": { "author": "Sarah M.", "rating": 5, "text": "I'm blown away by the quality and style of the clothes I received. Every piece has exceeded my expectations." } },
        { "type": "review", "settings": { "author": "Alex K.", "rating": 5, "text": "Finding clothes that align with my personal style used to be a challenge until I discovered Shop.co. The range of options is truly remarkable." } },
        { "type": "review", "settings": { "author": "James L.", "rating": 5, "text": "As someone who's always on the lookout for unique fashion pieces, I'm thrilled. The selection is not only diverse but also on-point with the latest trends." } },
        { "type": "review", "settings": { "author": "Olivia P.", "rating": 4, "text": "Absolutely love the quality of their clothes. The stitching and fabric are top-notch and it's clear the team cares about craftsmanship." } }
      ]
    }
  ]
}
{% endschema %}
