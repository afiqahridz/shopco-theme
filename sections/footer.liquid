<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">

      <!-- Brand col -->
      <div class="footer-brand">
        <div class="footer-brand__logo">{{ shop.name }}</div>
        <p class="footer-brand__desc">{{ section.settings.brand_desc }}</p>
        <div class="footer-social">
          {% if section.settings.social_twitter != blank %}
            <a href="{{ section.settings.social_twitter }}" class="social-icon" aria-label="Twitter" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_facebook != blank %}
            <a href="{{ section.settings.social_facebook }}" class="social-icon" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_instagram != blank %}
            <a href="{{ section.settings.social_instagram }}" class="social-icon" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_github != blank %}
            <a href="{{ section.settings.social_github }}" class="social-icon" aria-label="GitHub" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Link columns from blocks -->
      {% for block in section.blocks %}
        {% if block.type == 'link_column' %}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul>
              {% for i in (1..6) %}
                {% assign link_text_key = 'link_' | append: i | append: '_text' %}
                {% assign link_url_key = 'link_' | append: i | append: '_url' %}
                {% assign link_text = block.settings[link_text_key] %}
                {% assign link_url = block.settings[link_url_key] %}
                {% if link_text != blank %}
                  <li><a href="{{ link_url | default: '#' }}">{{ link_text }}</a></li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}

    </div>

    <!-- Footer bottom -->
    <div class="footer-bottom">
      <p>{{ shop.name }} &copy; {{ 'now' | date: '%Y' }}, All Rights Reserved</p>
      <div class="payment-icons">
        <!-- Visa -->
        <div class="payment-icon" title="Visa">
          <svg height="16" viewBox="0 0 50 16" fill="none" xmlns="http://www.w3.org/2000/svg"><text x="2" y="13" font-family="Arial" font-weight="bold" font-size="13" fill="#1A1F71">VISA</text></svg>
        </div>
        <!-- Mastercard -->
        <div class="payment-icon" title="Mastercard">
          <svg height="20" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="14" cy="12" r="10" fill="#EB001B"/>
            <circle cx="24" cy="12" r="10" fill="#F79E1B"/>
            <path d="M19 4.9a10 10 0 0 1 0 14.2A10 10 0 0 1 19 4.9z" fill="#FF5F00"/>
          </svg>
        </div>
        <!-- PayPal -->
        <div class="payment-icon" title="PayPal">
          <svg height="16" viewBox="0 0 60 16" fill="none"><text x="2" y="13" font-family="Arial" font-weight="bold" font-size="12" fill="#003087">Pay</text><text x="22" y="13" font-family="Arial" font-weight="bold" font-size="12" fill="#009CDE">Pal</text></svg>
        </div>
        <!-- Apple Pay -->
        <div class="payment-icon" title="Apple Pay">
          <svg height="16" viewBox="0 0 50 16" fill="none"><text x="2" y="13" font-family="Arial" font-size="11" fill="#000"> Pay</text></svg>
        </div>
        <!-- Google Pay -->
        <div class="payment-icon" title="Google Pay">
          <svg height="16" viewBox="0 0 60 16" fill="none"><text x="1" y="13" font-family="Arial" font-size="11" fill="#5F6368">G Pay</text></svg>
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "brand_desc", "label": "Brand description", "default": "We have clothes that suits your style and which you're proud to wear. From women to men." },
    { "type": "text", "id": "social_twitter", "label": "Twitter URL" },
    { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
    { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
    { "type": "text", "id": "social_github", "label": "GitHub URL" }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "heading", "label": "Column heading", "default": "Company" },
        { "type": "text", "id": "link_1_text", "label": "Link 1 text", "default": "About" },
        { "type": "url",  "id": "link_1_url",  "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_text", "label": "Link 2 text", "default": "Features" },
        { "type": "url",  "id": "link_2_url",  "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_text", "label": "Link 3 text", "default": "Works" },
        { "type": "url",  "id": "link_3_url",  "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_text", "label": "Link 4 text", "default": "Career" },
        { "type": "url",  "id": "link_4_url",  "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_text", "label": "Link 5 text" },
        { "type": "url",  "id": "link_5_url",  "label": "Link 5 URL" },
        { "type": "text", "id": "link_6_text", "label": "Link 6 text" },
        { "type": "url",  "id": "link_6_url",  "label": "Link 6 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_column", "settings": { "heading": "Company", "link_1_text": "About", "link_2_text": "Features", "link_3_text": "Works", "link_4_text": "Career" } },
        { "type": "link_column", "settings": { "heading": "Help", "link_1_text": "Customer Support", "link_2_text": "Delivery Details", "link_3_text": "Terms & Conditions", "link_4_text": "Privacy Policy" } },
        { "type": "link_column", "settings": { "heading": "FAQ", "link_1_text": "Account", "link_2_text": "Manage Deliveries", "link_3_text": "Orders", "link_4_text": "Payments" } },
        { "type": "link_column", "settings": { "heading": "Resources", "link_1_text": "Free eBooks", "link_2_text": "Development Tutorial", "link_3_text": "How to - Blog", "link_4_text": "Youtube Playlist" } }
      ]
    }
  ]
}
{% endschema %}
