{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign featured_image = current_variant.featured_image | default: product.featured_image -%}

<section class="product-page" aria-label="{{ product.title }}">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb" style="margin-bottom:24px;">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span aria-hidden="true">›</span>
      {% endif %}
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="product-layout">

      <!-- Gallery -->
      <div class="product-gallery">
        <!-- Thumbnails -->
        <div class="product-thumbs" role="list" aria-label="Product images">
          {%- for image in product.images limit: 5 -%}
            <button
              class="product-thumb{% if forloop.first %} active{% endif %}"
              data-src="{{ image | image_url: width: 800 }}"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | image_url: width: 160 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                width="80"
                height="96"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>

        <!-- Main image -->
        <div class="product-main-image">
          <img
            id="main-product-image"
            src="{{ featured_image | image_url: width: 800 }}"
            srcset="{{ featured_image | image_url: width: 400 }} 400w,
                    {{ featured_image | image_url: width: 800 }} 800w,
                    {{ featured_image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="{{ featured_image.alt | default: product.title | escape }}"
            width="800"
            height="800"
            loading="eager"
            fetchpriority="high"
          >
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-info">
        <h1 class="product-info__title">{{ product.title }}</h1>

        <!-- Rating -->
        <div class="product-info__rating">
          {%- assign rating_value = product.metafields.reviews.rating.value | default: 4.5 | times: 1.0 -%}
          {%- assign review_count = product.metafields.reviews.rating_count.value | default: 0 -%}
          <div class="stars" aria-label="Rated {{ rating_value }} out of 5">
            {%- for i in (1..5) -%}
              <span class="star" aria-hidden="true">{%- if i <= rating_value -%}★{%- else -%}☆{%- endif -%}</span>
            {%- endfor -%}
          </div>
          <span style="font-size:14px;color:var(--color-muted);">{{ rating_value }}/5 ({{ review_count }} reviews)</span>
        </div>

        <!-- Price -->
        <div class="product-info__price">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="price price--sale">{{ current_variant.price | money }}</span>
            <span class="price price--compare">{{ current_variant.compare_at_price | money }}</span>
            {%- assign discount_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
            <span class="discount-badge">-{{ discount_pct }}%</span>
          {%- else -%}
            <span class="price">{{ current_variant.price | money }}</span>
          {%- endif -%}
        </div>

        <!-- Description -->
        <div class="product-info__desc">
          {{ product.description }}
        </div>

        <!-- Product Form -->
        {%- form 'product', product, id: 'product-form', novalidate: true -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <!-- Color Option -->
          {%- for option in product.options_with_values -%}
            {%- if option.name == 'Color' or option.name == 'Colour' -%}
              <div class="option-group">
                <p class="option-label">Select Color: <strong>{{ current_variant.option1 }}</strong></p>
                <div class="color-swatches">
                  {%- for value in option.values -%}
                    {%- assign swatch_id = 'swatch-' | append: option.name | append: '-' | append: value | handleize -%}
                    <input type="radio" name="option-{{ option.position }}" id="{{ swatch_id }}" value="{{ value }}" {% if value == current_variant.option1 %}checked{% endif %} style="display:none;">
                    <label
                      for="{{ swatch_id }}"
                      class="color-swatch{% if value == current_variant.option1 %} active{% endif %}"
                      title="{{ value }}"
                      aria-label="{{ value }}"
                      style="background:{{ value | downcase }};"
                    ></label>
                  {%- endfor -%}
                </div>
              </div>
            {%- elsif option.name == 'Size' -%}
              <div class="option-group">
                <p class="option-label">Choose Size</p>
                <div class="size-chips">
                  {%- for value in option.values -%}
                    {%- assign chip_id = 'size-' | append: value | handleize -%}
                    <input type="radio" name="option-{{ option.position }}" id="{{ chip_id }}" value="{{ value }}" {% if value == current_variant.option2 or value == current_variant.option1 %}checked{% endif %} style="display:none;">
                    <label
                      for="{{ chip_id }}"
                      class="size-chip{% if value == current_variant.option2 or value == current_variant.option1 %} active{% endif %}"
                    >{{ value }}</label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}

          <!-- Quantity + Add to Cart -->
          <div style="display:flex;align-items:center;gap:16px;margin-top:24px;flex-wrap:wrap;">
            <div class="quantity-selector" data-qty-wrap aria-label="Quantity">
              <button type="button" class="qty-btn" data-qty-minus aria-label="Decrease quantity">−</button>
              <input class="qty-input" type="number" name="quantity" value="1" min="1" max="99" data-qty-input aria-label="Quantity">
              <button type="button" class="qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
            </div>

            <div class="add-to-cart-row" style="flex:1;">
              <button
                type="submit"
                name="add"
                class="btn btn--primary"
                data-add-to-cart
                {% unless current_variant.available %}disabled{% endunless %}
                style="flex:1;"
              >
                {% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
              </button>

              <button type="button" class="wishlist-btn" aria-label="Add to wishlist">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
            </div>
          </div>

        {%- endform -%}

        <!-- Trust badges -->
        <div style="display:flex;gap:20px;margin-top:24px;padding-top:24px;border-top:1px solid var(--color-border);flex-wrap:wrap;">
          {%- for badge in 'Free Shipping over $100,Easy 30-Day Returns,Secure Checkout' | split: ',' -%}
            <div style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--color-muted);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {{ badge }}
            </div>
          {%- endfor -%}
        </div>

      </div>
    </div>

    <!-- Product Tabs: Description / Reviews / Details -->
    <div style="margin-top:60px;" data-tabs>
      <div class="tabs" role="tablist">
        <button class="tab-btn active" data-tab="description" role="tab" aria-selected="true">Product Details</button>
        <button class="tab-btn" data-tab="reviews" role="tab" aria-selected="false">
          Rating & Reviews
          <span style="margin-left:6px;background:var(--color-input-bg);border-radius:var(--radius-pill);padding:2px 8px;font-size:12px;">{{ review_count | default: 0 }}</span>
        </button>
        <button class="tab-btn" data-tab="faqs" role="tab" aria-selected="false">FAQs</button>
      </div>

      <div class="tab-panel active" data-panel="description" role="tabpanel">
        <div style="max-width:720px;color:var(--color-muted);line-height:1.8;font-size:15px;">
          {{ product.description }}
        </div>
      </div>

      <div class="tab-panel" data-panel="reviews" role="tabpanel">
        <div style="display:grid;grid-template-columns:240px 1fr;gap:48px;align-items:start;">
          <!-- Rating summary -->
          <div style="background:var(--color-bg);border-radius:var(--radius-lg);padding:28px;text-align:center;">
            <div style="font-size:64px;font-weight:700;line-height:1;">{{ rating_value | round: 1 }}</div>
            <div class="stars" style="justify-content:center;margin:8px 0;" aria-label="Average rating">
              {%- for i in (1..5) -%}<span class="star">★</span>{%- endfor -%}
            </div>
            <p style="font-size:14px;color:var(--color-muted);">Based on {{ review_count | default: 0 }} reviews</p>
          </div>
          <!-- Reviews list placeholder -->
          <div>
            <p style="color:var(--color-muted);font-size:15px;">Customer reviews will appear here once your review app is connected.</p>
          </div>
        </div>
      </div>

      <div class="tab-panel" data-panel="faqs" role="tabpanel">
        <div style="max-width:720px;">
          {%- for faq in 'What is the material?,How do I care for this item?,What sizes are available?,What is your return policy?' | split: ',' -%}
            <details style="border-bottom:1px solid var(--color-border);padding:16px 0;">
              <summary style="font-weight:600;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
                {{ faq }}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <p style="margin-top:12px;color:var(--color-muted);font-size:15px;line-height:1.7;">
                Please contact us or check the product description for details about this product.
              </p>
            </details>
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</section>

<script>
// Variant selection
(function(){
  const form = document.getElementById('product-form');
  if (!form) return;
  const variants = {{ product.variants | json }};

  function getSelectedOptions() {
    const opts = {};
    form.querySelectorAll('input[type="radio"]:checked').forEach(input => {
      const pos = parseInt(input.name.replace('option-', ''));
      opts[pos] = input.value;
    });
    return opts;
  }

  function findVariant(opts) {
    return variants.find(v => {
      return Object.entries(opts).every(([pos, val]) => v['option' + pos] === val);
    });
  }

  form.addEventListener('change', function(e) {
    if (!e.target.name?.startsWith('option-')) return;
    const opts = getSelectedOptions();
    const variant = findVariant(opts);
    if (!variant) return;

    // Update hidden ID
    form.querySelector('input[name="id"]').value = variant.id;

    // Update price
    const priceEl = form.closest('.product-info')?.querySelector('.price');
    if (priceEl && variant.price) {
      const formatted = (variant.price / 100).toLocaleString('en-US', { style: 'currency', currency: '{{ shop.currency }}' });
      priceEl.textContent = formatted;
    }

    // Update main image
    if (variant.featured_image) {
      const img = document.getElementById('main-product-image');
      if (img) img.src = variant.featured_image.src;
    }

    // Update button
    const btn = form.querySelector('[data-add-to-cart]');
    if (btn) {
      btn.disabled = !variant.available;
      btn.textContent = variant.available ? 'Add to Cart' : 'Sold Out';
    }
  });
})();
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [],
  "presets": [{ "name": "Product Page" }]
}
{% endschema %}
