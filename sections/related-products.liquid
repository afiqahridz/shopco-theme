<section class="products-section section" aria-label="{{ section.settings.heading }}">
  <div class="container">
    <h2 class="section-title" data-animate>{{ section.settings.heading }}</h2>
    <div class="products-grid">
      {%- assign related_products = product.collections.first.products -%}
      {%- assign shown = 0 -%}
      {%- for related in related_products -%}
        {%- if related.id != product.id and shown < section.settings.products_to_show -%}
          {% render 'product-card', product: related %}
          {%- assign shown = shown | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Related Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You Might Also Like" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 8, "step": 1, "label": "Products to show", "default": 4 }
  ],
  "presets": [{ "name": "Related Products" }]
}
{% endschema %}
