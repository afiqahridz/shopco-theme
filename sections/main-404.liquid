<section style="text-align:center;padding:120px 24px;">
  <h1 style="font-size:clamp(80px,15vw,160px);font-family:var(--font-main);font-weight:700;line-height:1;margin-bottom:0;opacity:0.08;">404</h1>
  <h2 style="font-size:clamp(24px,4vw,40px);margin-top:-20px;margin-bottom:16px;text-transform:uppercase;">Page Not Found</h2>
  <p style="color:var(--color-muted);font-size:16px;max-width:440px;margin:0 auto 40px;line-height:1.7;">
    Sorry, the page you were looking for doesn't exist or has been moved.
  </p>
  <a href="/" class="btn btn--primary">Back to Homepage</a>
</section>

{% schema %}
{
  "name": "404 Page",
  "settings": [],
  "presets": [{ "name": "404 Page" }]
}
{% endschema %}
