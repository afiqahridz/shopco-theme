<section class="style-section section" aria-label="Browse by dress style">
  <div class="container">
    <h2 class="section-title" data-animate>Browse by Dress Style</h2>

    <div class="style-grid">
      {% assign first = true %}
      {% for block in section.blocks %}
        {% if block.type == 'style' %}
          <a
            href="{{ block.settings.url }}"
            class="style-card{% if first %} style-card--tall{% endif %}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.label }}"
                width="800"
                height="{{ first | ternary: 600, 300 }}"
                loading="lazy"
              >
            {% else %}
              <div style="width:100%;height:100%;min-height:250px;background:var(--color-border);display:flex;align-items:flex-end;padding:20px;">
              </div>
            {% endif %}
            <span class="style-card__label">{{ block.settings.label }}</span>
          </a>
          {% assign first = false %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Browse by Style",
  "blocks": [
    {
      "type": "style",
      "name": "Style Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Casual" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Browse by Style",
      "blocks": [
        { "type": "style", "settings": { "label": "Casual" } },
        { "type": "style", "settings": { "label": "Formal" } },
        { "type": "style", "settings": { "label": "Party" } },
        { "type": "style", "settings": { "label": "Gym" } }
      ]
    }
  ]
}
{% endschema %}
