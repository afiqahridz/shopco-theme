<section class="hero" aria-label="Hero banner">
  <div class="hero__inner container">
    <div class="hero__content" data-animate>

      <h1 class="hero__title">{{ section.settings.heading }}</h1>

      <p class="hero__desc">{{ section.settings.subheading }}</p>

      <div class="hero__actions">
        <a href="{{ section.settings.cta_url }}" class="btn btn--primary">
          {{ section.settings.cta_text }}
        </a>
        {% if section.settings.secondary_cta_text != blank %}
          <a href="{{ section.settings.secondary_cta_url }}" class="btn btn--outline">
            {{ section.settings.secondary_cta_text }}
          </a>
        {% endif %}
      </div>

      <div class="hero__stats">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="hero__stat-item" {{ block.shopify_attributes }}>
              <span class="hero__stat-number">{{ block.settings.number }}</span>
              <span class="hero__stat-label">{{ block.settings.label }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>

    </div>

    <div class="hero__image-wrap">
      {% if section.settings.hero_image %}
        <img
          class="hero__image"
          src="{{ section.settings.hero_image | image_url: width: 700 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 400 }} 400w,
                  {{ section.settings.hero_image | image_url: width: 700 }} 700w,
                  {{ section.settings.hero_image | image_url: width: 900 }} 900w"
          sizes="(max-width: 768px) 0vw, 50vw"
          alt="{{ section.settings.hero_image.alt | default: shop.name }}"
          width="700"
          height="650"
          loading="eager"
          fetchpriority="high"
        >
      {% else %}
        <div style="width:100%;height:560px;background:var(--color-border);border-radius:16px;display:flex;align-items:center;justify-content:center;color:#999;font-size:14px;">
          Add hero image in theme editor
        </div>
      {% endif %}

      <!-- Decorative stars -->
      <svg class="hero__star-1" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M25 0 L27.5 22.5 L50 25 L27.5 27.5 L25 50 L22.5 27.5 L0 25 L22.5 22.5 Z" fill="black"/>
      </svg>
      <svg class="hero__star-2" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M15 0 L16.5 13.5 L30 15 L16.5 16.5 L15 30 L13.5 16.5 L0 15 L13.5 13.5 Z" fill="black"/>
      </svg>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Clothes That Matches Your Style"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse through our diverse range of meticulously crafted garments, designed to bring out your individuality and cater to your sense of style."
    },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Shop Now" },
    { "type": "url", "id": "cta_url", "label": "Button URL" },
    { "type": "text", "id": "secondary_cta_text", "label": "Secondary button text" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary button URL" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "number", "label": "Stat number", "default": "200+" },
        { "type": "text", "id": "label", "label": "Stat label", "default": "International Brands" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "stat", "settings": { "number": "200+", "label": "International Brands" } },
        { "type": "stat", "settings": { "number": "2,000+", "label": "High-Quality Products" } },
        { "type": "stat", "settings": { "number": "30,000+", "label": "Happy Customers" } }
      ]
    }
  ]
}
{% endschema %}
