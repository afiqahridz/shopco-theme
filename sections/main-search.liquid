<section class="collection-page section--lg">
  <div class="container">
    <div class="collection-header">
      <h1>
        {%- if search.performed -%}
          Search results for "{{ search.terms | escape }}"
        {%- else -%}
          Search
        {%- endif -%}
      </h1>
    </div>

    <!-- Search form -->
    <form action="/search" method="get" role="search" style="max-width:560px;margin-bottom:40px;">
      <input type="hidden" name="type" value="product">
      <div class="search-input" style="border:1px solid var(--color-border);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products..." aria-label="Search" autofocus>
        <button type="submit" class="btn btn--primary btn--sm">Search</button>
      </div>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p style="color:var(--color-muted);font-size:14px;margin-bottom:32px;">{{ search.results_count }} results for "{{ search.terms | escape }}"</p>
        {%- paginate search.results by 12 -%}
          <div class="products-grid">
            {%- for result in search.results -%}
              {%- if result.object_type == 'product' -%}
                {% render 'product-card', product: result %}
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="pagination" aria-label="Search pagination">
              {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="page-btn">‹</a>{%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="page-btn">{{ part.title }}</a>
                {%- else -%}
                  <span class="page-btn{% if part.title == paginate.current_page %} active{% endif %}">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="page-btn">›</a>{%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- else -%}
        <div style="text-align:center;padding:60px 0;color:var(--color-muted);">
          <p style="font-size:18px;margin-bottom:16px;">No results for "{{ search.terms | escape }}"</p>
          <p>Try checking your spelling or using more general terms.</p>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search Results",
  "settings": [],
  "presets": [{ "name": "Search Results" }]
}
{% endschema %}
